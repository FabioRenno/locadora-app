# CÓPIE ESTE ARQUIVO para .env e preencha com seus dados.
# Comando: copie .env.example e renomeie para .env
# O .env NÃO vai para o Git (seguro para senhas).

# Banco de dados PostgreSQL (Neon, Render, Railway)
# Neon: https://neon.tech - crie projeto e copie a connection string
# Exemplo: postgresql://usuario:senha@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require

# Sessão (produção: use valor aleatório longo)
# Gere em: https://randomkeygen.com
# SESSION_SECRET=sua-chave-secreta-aqui

# E-mail - notifica o locador quando um motorista manifesta interesse
# Gmail: crie "senha de app" em https://myaccount.google.com/apppasswords
# A senha de app tem espaços - use aspas: EMAIL_PASS="abcd efgh ijkl mnop"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS="sua-senha-de-app-com-16-caracteres"
EMAIL_FROM=seu-email@gmail.com

# URL base (opcional - para link no e-mail)
# APP_URL=http://localhost:3000
